# ---- LineageIQ environment (copy to .env) ----

# App
LINEAGEIQ_ENV=local
LOG_LEVEL=INFO

# Database
# Postgres (default for docker compose):
DATABASE_URL=postgresql+psycopg://lineageiq:lineageiq@localhost:5432/lineageiq
# Read-only role used by the SQL agent tool (defense in depth):
DATABASE_URL_RO=postgresql+psycopg://lineageiq_ro:lineageiq_ro@localhost:5432/lineageiq
# Local SQLite alternative (no Postgres needed):
# DATABASE_URL=sqlite:///./data/generated/lineageiq.db

# Determinism
RANDOM_SEED=20240601

# LLM provider (provider-independent). Use "fake" for tests/CI.
LLM_PROVIDER=fake
LLM_MODEL=claude-fake-1
LLM_API_KEY=
LLM_BASE_URL=
LLM_INPUT_COST_PER_1K=0.0
LLM_OUTPUT_COST_PER_1K=0.0

# Agent budgets
AGENT_MAX_TOOL_CALLS=8
AGENT_MAX_SQL_RETRIES=2
AGENT_MAX_DURATION_SECONDS=120
AGENT_MAX_TOKENS=20000
AGENT_COST_CEILING_USD=1.0

# SQL tool limits
SQL_ROW_LIMIT=200
SQL_TIMEOUT_SECONDS=5
SQL_MAX_QUERY_LENGTH=4000

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=lineageiq-backend

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
